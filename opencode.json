        "composer-2": {
          "name": "Composer 2"
        },
        "composer-2-fast": {
          "name": "Composer 2 (Fast)"
        },
        "gpt-5.5-medium": {
          "name": "GPT-5.5 1M"
        },
        "claude-4.6-sonnet-medium": {
          "name": "Claude 4.6 Sonnet (Medium)"
        },
        "gpt-5.4-medium": {
          "name": "GPT-5.4 1M"
        },
        "gpt-5-mini": {
          "name": "GPT-5 Mini"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      }
    }
  },
  "mcp": {}
